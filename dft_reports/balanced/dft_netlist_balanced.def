       Y_reg[3] ( IN SI ) ( OUT Q ) 
       Y_reg[4] ( IN SI ) ( OUT Q ) 
       Y_reg[5] ( IN SI ) ( OUT Q ) 
       Y_reg[6] ( IN SI ) ( OUT Q ) 
       Y_reg[7] ( IN SI ) ( OUT Q ) 
       out1_reg[0] ( IN SI ) ( OUT Q ) 
